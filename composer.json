{
    "name": "haosheng0211/laravel-captcha",
    "description": "A Laravel package providing unified captcha verification with support for reCAPTCHA, Turnstile, and hCaptcha",
    "keywords": [
        "MrJin",
        "laravel",
        "laravel-captcha"
    ],
    "homepage": "https://github.com/haosheng0211/laravel-captcha",
    "license": "MIT",
    "authors": [
        {
            "name": "Mr.Jin",
            "email": "haosheng0211@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^10.0||^11.0||^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^10.0.0||^9.0.0||^8.0.0",
        "pestphp/pest": "^2.0||^3.0||^4.0",
        "pestphp/pest-plugin-arch": "^2.0||^3.0||^4.0",
        "pestphp/pest-plugin-laravel": "^2.0||^3.0||^4.0",
        "spatie/laravel-ray": "^1.35"
    },
    "autoload": {
        "psr-4": {
            "MrJin\\Captcha\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MrJin\\Captcha\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MrJin\\Captcha\\CaptchaServiceProvider"
            ],
            "aliases": {
                "Captcha": "MrJin\\Captcha\\Facades\\Captcha"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
